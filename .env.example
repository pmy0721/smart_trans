# Copy to .env and fill in values. Do NOT commit real secrets.

# LLM (SiliconFlow OpenAI-compatible)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-VL-32B-Instruct

# Triplet summary (DeepSeek-V3.2, OpenAI-compatible)
# If omitted, backend falls back to SILICONFLOW_* for both base_url and api_key.
# SMART_TRANS_SUMMARY_API_KEY=
# SMART_TRANS_SUMMARY_BASE_URL=https://api.siliconflow.cn/v1
# SMART_TRANS_SUMMARY_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# Law RAG (optional)
# Knowledge base generated by: python tools/build_law_kb.py
# SMART_TRANS_LAW_KB=rag/law_kb.jsonl
# SMART_TRANS_LAW_API_KEY= (defaults to SMART_TRANS_SUMMARY_API_KEY/SILICONFLOW_API_KEY)
# SMART_TRANS_LAW_BASE_URL= (defaults to SMART_TRANS_SUMMARY_BASE_URL/SILICONFLOW_BASE_URL)
# SMART_TRANS_LAW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# Frontend map (AMap / Gaode)
# Note: Vite only injects VITE_* vars at build time.
# VITE_AMAP_KEY=
# VITE_AMAP_SECURITY_CODE=
# VITE_AMAP_COORD_MODE=gps

# Backend (optional)
# SMART_TRANS_DB=backend/data/accidents.db
# SMART_TRANS_UPLOADS=backend/uploads
# SMART_TRANS_CORS_ORIGIN=http://localhost:25173

# Ingest jobs (optional)
# SMART_TRANS_INCOMING_DIR=incoming
# SMART_TRANS_PIPELINE_MAX_CONCURRENCY=1
# SMART_TRANS_PIPELINE_MAX_INFLIGHT=0

# Huawei Cloud IoTDA Beeper (optional)
# Note: beep_mcp_server requires all fields below; there are no insecure built-in defaults.
# HUAWEICLOUD_AK=
# HUAWEICLOUD_SK=
# HUAWEICLOUD_ENDPOINT=
# HUAWEICLOUD_REGION_ID=
# HUAWEICLOUD_DEVICE_ID=

# Beep MCP (optional)
# SMART_TRANS_ENABLE_BEEP=1
# SMART_TRANS_DISABLE_BEEP=0
# SMART_TRANS_EARLY_BEEP=1
# SMART_TRANS_BEEP_MCP_URL=http://localhost:9010/sse
# SMART_TRANS_BEEP_MCP_PORT=9010
# SMART_TRANS_BEEP_ON_TIME=0.3
# SMART_TRANS_BEEP_GAP=0.3

# Auto stamp HZ coords onto ingested images (optional)
# SMART_TRANS_STAMP_COORDS=1
# SMART_TRANS_STAMP_HZ_BBOX=30.18,30.35,120.05,120.25
# SMART_TRANS_STAMP_SEED=42
